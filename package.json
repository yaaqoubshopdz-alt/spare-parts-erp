{
  "name": "spare-parts-erp",
  "version": "1.0.1",
  "description": "Spare Parts ERP - نظام إدارة قطع الغيار",
  "main": "dist/electron/main.js",
  "scripts": {
    "archive-legacy": "node scripts/archive_legacy.js",
    "git-info": "node git_info.js",
    "dev": "vite",
    "build": "tsc && vite build && node scripts/generate-manifest.js",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder",
    "build:win": "npm run build && electron-builder --win",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ericblade/quagga2": "^1.8.4",
    "@hookform/resolvers": "^3.3.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@tanstack/react-table": "^8.12.0",
    "@tanstack/react-virtual": "^3.0.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.0.0",
    "drizzle-orm": "^0.29.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "framer-motion": "^12.38.0",
    "i18next": "^23.7.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.0",
    "lucide-react": "^0.303.0",
    "node-schedule": "^2.1.1",
    "numeral": "^2.0.6",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-barcode": "^1.5.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.0",
    "react-hot-toast": "^2.4.0",
    "react-i18next": "^14.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.21.0",
    "react-to-print": "^2.15.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.10.6",
    "@types/node-schedule": "^2.1.5",
    "@types/numeral": "^2.0.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.20.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^1.6.1"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.spareparts.erp",
    "productName": "SparePartsERP",
    "publish": [
      {
        "provider": "github",
        "owner": "yaaqoubshopdz-alt",
        "repo": "spare-parts-erp"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "database/**/*",
      "resources/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "database",
        "to": "database",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "SparePartsERP"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    }
  }
}
