# Bolbul ERP — Multi-Agent System Configuration
# Copy this file to .env and fill in your values

# OpenAI-compatible API settings
# If using Hermes, these are usually auto-detected from Hermes config
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
AGENT_MODEL=gpt-4o-mini

# Optional: Override per-agent settings
# ATLAS_MODEL=gpt-4
# ECHO_MODEL=gpt-4o-mini
# RAZ_MODEL=gpt-4
# ARYA_MODEL=gpt-4o-mini
